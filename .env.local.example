AI_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# To use Qwen / Alibaba Cloud Model Studio, change AI_PROVIDER to qwen.
# For meal photo analysis, use a vision-capable Qwen model.
# China endpoint:
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen3-vl-plus
# Optional fallback vision model if QWEN_MODEL is changed to a text-only model.
QWEN_VISION_MODEL=qwen3-vl-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# International endpoint example:
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
